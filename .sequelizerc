const path = require('path');

// Use __dirname so paths are always relative to THIS file's location,
// not to whatever directory the command is run from.
// This fixes the Render error: "scandir '/opt/render/project/src/migrations'"
// which happened because path.resolve() was relative to the shell's cwd.

module.exports = {
  'config':           path.join(__dirname, 'config', 'config.js'),
  'migrations-path':  path.join(__dirname, 'src', 'migrations'),
  'seeders-path':     path.join(__dirname, 'src', 'seeders'),
  'models-path':      path.join(__dirname, 'src', 'models'),
};
