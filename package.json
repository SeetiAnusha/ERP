{
  "name": "erp-backend",
  "version": "1.0.0",
  "description": "ERP System Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run build && npm start",
    "build": "./node_modules/.bin/tsc",
    "build:prod": "./node_modules/.bin/tsc && npx sequelize-cli db:migrate",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:create": "npx sequelize-cli migration:generate --name",
    "migrate:production": "NODE_ENV=production npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "db:seed": "npx sequelize-cli db:seed:all",
    "check-tables": "node check-missing-tables.js",
    "create-tables": "node force-create-tables.js",
    "test-db": "node test-connection.js"
  },
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.4.0",
    "@types/socket.io": "^3.0.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@types/yamljs": "^0.2.34",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.32.1",
    "sequelize-cli": "^6.6.5",
    "socket.io": "^4.8.3",
    "swagger-autogen": "^2.23.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/ioredis": "^4.28.10",
    "@types/multer": "^2.1.0",
    "@types/xlsx": "^0.0.35",
    "fast-check": "^4.6.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
