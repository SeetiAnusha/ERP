{
  "name": "erp-backend",
  "version": "1.0.0",
  "description": "ERP System Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run build && npm start",
    "dev:watch": "npx tsc --watch",
    "dev:ts": "npx ts-node src/index.ts",
    "build": "npx tsc",
    "build:clean": "npx rimraf dist && npx tsc",
    "build:prod": "npm install && npx tsc",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "migrate:undo:all": "npx sequelize-cli db:migrate:undo:all",
    "migrate:status": "npx sequelize-cli db:migrate:status",
    "migrate:create": "npx sequelize-cli migration:generate --name",
    "migrate:production": "NODE_ENV=production npx sequelize-cli db:migrate",
    "init-db": "npx tsx src/scripts/initializeDatabase.ts",
    "audit-schema": "npx tsx src/scripts/comprehensiveSchemaAudit.ts",
    "fix-all-schemas": "npx tsx src/scripts/autoFixAllSchemas.ts",
    "add-soft-delete-columns": "npx tsx src/scripts/addMissingSoftDeleteColumns.ts",
    "migrate:staging": "NODE_ENV=staging npx sequelize-cli db:migrate",
    "seed": "npx sequelize-cli db:seed:all",
    "seed:undo": "npx sequelize-cli db:seed:undo:all",
    "accounting:init": "npx ts-node src/scripts/initializeAccounting.ts",
    "accounting:verify": "npx ts-node src/scripts/verifyAccounting.ts",
    "verify-schemas": "npx tsx src/scripts/verifyAllSchemas.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.4.0",
    "@types/socket.io": "^3.0.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@types/yamljs": "^0.2.34",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.32.1",
    "socket.io": "^4.8.3",
    "swagger-autogen": "^2.23.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/multer": "^2.1.0",
    "@types/xlsx": "^0.0.35",
    "fast-check": "^4.6.0",
    "jest": "^30.3.0",
    "rimraf": "^5.0.5",
    "sequelize-cli": "^6.6.5",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
