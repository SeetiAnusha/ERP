{
  "name": "erp-backend",
  "version": "1.0.0",
  "description": "ERP System Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run build && npm start",
    "dev:watch": "npx tsc --watch",
    "dev:ts": "npx ts-node src/index.ts",
    "build": "npx tsc",
    "build:clean": "npx rimraf dist && npx tsc",
    "build:prod": "npm install && npx tsc",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "db:init": "node scripts/init-database.js",
    "db:init:complete": "node scripts/init-database-complete.js",
    "db:init:safe": "node scripts/safe-db-init.js",
    "db:create:all": "node scripts/create-all-tables.js",
    "db:reset": "NODE_ENV=production node scripts/init-database-complete.js",
    "db:force": "NODE_ENV=production node -e \"const {Sequelize} = require('sequelize'); const s = new Sequelize(process.env.DATABASE_URL, {dialect:'postgres', dialectOptions:{ssl:{require:true, rejectUnauthorized:false}}, logging:console.log}); require('./dist/models/associations'); s.sync({force:true}).then(() => {console.log('✅ All tables created'); process.exit(0);}).catch(e => {console.error('❌', e); process.exit(1);});\"",
    "insert:production:data": "node scripts/insert-production-data.js",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/uuid": "^10.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.32.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "fast-check": "^4.6.0",
    "jest": "^30.3.0",
    "rimraf": "^5.0.5",
    "sequelize-cli": "^6.6.5",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
