{
  "name": "erp-backend",
  "version": "1.0.0",
  "description": "ERP System Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run build && npm start",
    "dev:watch": "./node_modules/.bin/tsc --watch & npm start",
    "dev:ts": "ts-node src/index.ts",
    "build": "./node_modules/.bin/tsc",
    "build:clean": "rm -rf dist && ./node_modules/.bin/tsc",
    "build:prod": "NODE_ENV=production npm install && NODE_ENV=production ./node_modules/.bin/tsc",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/uuid": "^10.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.32.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "fast-check": "^4.6.0",
    "jest": "^30.3.0",
    "sequelize-cli": "^6.6.5",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
